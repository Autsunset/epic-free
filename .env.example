# ====================================================================
# Epic account
# If a value contains $, \, #, or ` (e.g. some passwords), wrap it in single
# quotes so python-dotenv keeps it as a literal: EPIC_PASSWORD='abc$def'.
# This only affects local .env files; GitHub Actions Secrets are unaffected.
# ====================================================================
EPIC_EMAIL=your_email@example.com
EPIC_PASSWORD=your_password

# ====================================================================
# LLM provider — pick ONE: gemini | glm | openai
# Only fill in the *_API_KEY for the provider you chose.
# If LLM_PROVIDER is left blank it is auto-detected from the keys below.
# ====================================================================
LLM_PROVIDER=openai

# --- OpenAI / any OpenAI-compatible gateway (default) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# --- GLM (ZhipuAI / BigModel, also OpenAI-compatible) ---
# LLM_PROVIDER=glm
# GLM_API_KEY=
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# GLM_MODEL=glm-4.5v

# --- Official Gemini (or AiHubMix relay) ---
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_BASE_URL=          # leave empty for official Gemini; e.g. https://aihubmix.com
# GEMINI_MODEL=gemini-2.5-pro

# ====================================================================
# Optional per-task model overrides
# Leave empty to follow the chosen provider's default model automatically.
# ====================================================================
CHALLENGE_CLASSIFIER_MODEL=
IMAGE_CLASSIFIER_MODEL=
SPATIAL_POINT_REASONER_MODEL=
SPATIAL_PATH_REASONER_MODEL=

# ====================================================================
# Browser runtime
# Supported values: auto, camoufox, playwright
# ====================================================================
BROWSER_BACKEND=auto

# ====================================================================
# Local one-shot run (set true to disable the recurring scheduler)
# ====================================================================
ENABLE_APSCHEDULER=false
# HEADLESS=true
